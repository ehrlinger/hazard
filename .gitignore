# =============================================================================
# R / RStudio
# =============================================================================
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# =============================================================================
# Autoconf / Automake — generated by ./configure
# Kept in git:  configure, Makefile.am, Makefile.in, config.h.in, aclocal.m4
# Ignored here: everything produced when a user runs ./configure
# =============================================================================
/config.h
/config.log
/config.status
/stamp-h1
autom4te.cache/

# Generated Makefiles (Makefile.am and Makefile.in are source files — kept)
Makefile
!Makefile.am
!Makefile.in
# Hand-written Makefiles under tests/ are not generated by configure
!tests/unit/Makefile

# =============================================================================
# Build outputs — produced by make
# =============================================================================
# Intermediates
*.o
*.ko
*.obj
*.lo
*.la
.deps/
.libs/

# Libraries
*.a
*.lib
*.dll
*.so
*.so.*
*.dylib

# Generic executables
*.exe
*.elf
*.out
*.app
*.i*86
*.x86_64
*.hex

# HAZARD compiled executables
src/hazard/hazard
src/hazpred/hazpred
src/blackbox/blackbox
src/blackbox/hzpexmpl
src/blackbox/xpt2ascii

# Unit test binaries (sources live alongside as test_*.c)
tests/unit/test_math_helpers
tests/unit/test_shaping_functions
tests/unit/test_obs_layout
tests/unit/test_error_describe
tests/unit/test_log

# Acceptance-test capture kit (generated by `make capture-kit`)
hazard-capture-kit/
hazard-capture-kit.tar.gz

# Legacy runtime scratch artifacts
*.pcv
.pure
st0_*

# =============================================================================
# IDE — Eclipse CDT
# =============================================================================
.autotools
.cproject
.project
.settings/
Debug/

# =============================================================================
# Editor artifacts
# =============================================================================
*~
\#*\#
*.swp
*.swo
*.asv
bin.proj
.vscode/

# Local build/test logs
build-*.log
plain-configure.log

# Local Copilot/Claude scratch worktrees + per-user settings
# (must never be tracked — machine-local paths and tool allowlists leak
# filesystem details)
.claude/worktrees/
.claude/settings.local.json

# Historical capture artefacts (generated; see tests/corpus/ for the
# curated fixtures used by the harness)
/outputs/

# Local harness run artefacts — PROC HAZARD writes .haz bridge files next
# to its .dta inputs during acceptance runs.  Only the hazpred corpus
# ships tracked .haz bridges (intentionally, see tests/corpus/hazpred/);
# hazard-side .haz files are outputs and must stay untracked.
tests/corpus/hazard/inputs/*.haz

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble

# =============================================================================
# Debug symbols
# =============================================================================
*.dSYM/
*.gch
*.pch
