# =============================================================================
# R / RStudio
# =============================================================================
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# =============================================================================
# Autoconf / Automake — generated by ./configure
# Kept in git:  configure, Makefile.am, Makefile.in, config.h.in, aclocal.m4
# Ignored here: everything produced when a user runs ./configure
# =============================================================================
/config.h
/config.log
/config.status
/stamp-h1
autom4te.cache/

# Generated Makefiles (Makefile.am and Makefile.in are source files — kept)
Makefile
!Makefile.am
!Makefile.in
# Hand-written Makefiles under tests/ are not generated by configure
!tests/unit/Makefile

# =============================================================================
# Build outputs — produced by make
# =============================================================================
# Intermediates
*.o
*.ko
*.obj
*.lo
*.la
.deps/
.libs/

# Libraries
*.a
*.lib
*.dll
*.so
*.so.*
*.dylib

# Generic executables
*.exe
*.elf
*.out
*.app
*.i*86
*.x86_64
*.hex

# HAZARD compiled executables
src/hazard/hazard
src/hazpred/hazpred
src/blackbox/blackbox
src/blackbox/hzpexmpl
src/blackbox/xpt2ascii

# Legacy runtime scratch artifacts
*.pcv
.pure
st0_*

# =============================================================================
# IDE — Eclipse CDT
# =============================================================================
.autotools
.cproject
.project
.settings/
Debug/

# =============================================================================
# Editor artifacts
# =============================================================================
*~
\#*\#
*.swp
*.swo
*.asv
bin.proj
.vscode/

# Local build/test logs
build-*.log
plain-configure.log

# Local Copilot/Claude scratch worktrees (must never be tracked)
.claude/worktrees/

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble

# =============================================================================
# Debug symbols
# =============================================================================
*.dSYM/
*.gch
*.pch
